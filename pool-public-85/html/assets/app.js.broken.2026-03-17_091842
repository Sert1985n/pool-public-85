  function prettyDiffShort(diff, name){
    const d = n(diff, 0);
    const nm = String(name || '').toLowerCase();

    if (nm.includes('nerdminer') || d < 1) return '1 H';

    if (d >= 1000000){
      const v = d / 1000000;
      return `${(v >= 10 ? Math.round(v) : Math.round(v * 10) / 10).toString().replace(/\.0$/, '')} M`;
    }

    if (d >= 1000){
      const v = d / 1000;
      return `${(v >= 10 ? Math.round(v) : Math.round(v * 10) / 10).toString().replace(/\.0$/, '')} K`;
    }

    return `${Math.max(1, Math.round(d))} H`;
  }

