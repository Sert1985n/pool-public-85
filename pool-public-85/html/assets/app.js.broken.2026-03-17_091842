  function synthHomeChart(stats){
    const steps = 25;
    const now = Date.now();
    const start = now - 24 * 60 * 60 * 1000;
    const stepMs = (24 * 60 * 60 * 1000) / Math.max(1, steps - 1);
    const total = n(stats?.totalHashrate, 0);
    const diff = n(stats?.networkDifficulty, 0);
    const pts = [];

    for(let i=0; i<steps; i++){
      const t = Math.round(start + i * stepMs);
      const phase = i / Math.max(1, steps - 1);
      const wave1 = Math.sin(phase * Math.PI * 2.15) * 0.05;
      const wave2 = Math.cos(phase * Math.PI * 4.2) * 0.025;
      pts.push({
        t,
        h: total > 0 ? Math.max(0, total * (1 + wave1 + wave2)) : 0,
        d: diff
      });
    }
    return pts;
  }

