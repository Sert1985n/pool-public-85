  function synthHomeChart(stats){
    const steps = 25;
    const now = Date.now();
    const start = now - 24 * 60 * 60 * 1000;
    const stepMs = (24 * 60 * 60 * 1000) / (steps - 1);
    const total = n(stats && stats.totalHashrate, 0);
    const diff = n(stats && stats.networkDifficulty, 0);
    const pts = [];

    for(let i=0; i<steps; i++){
      const t = Math.round(start + i * stepMs);
      const phase = i / Math.max(1, steps - 1);
      const wave1 = Math.sin(phase * Math.PI * 2.2) * 0.05;
      const wave2 = Math.cos(phase * Math.PI * 5.1) * 0.025;
      const h = total > 0 ? Math.max(0, total * (1 + wave1 + wave2)) : 0;
      pts.push({ t, h, d: diff });
    }
    return pts;
  }

