    }).filter(p => p.t > 0).sort((a,b) => a.t - b.t);

    if (!pts.length) return [];
    return pts;
  }

  function densifyPoints(points, factor=4){
    if (!Array.isArray(points) || points.length < 2) return points || [];
    const out = [];
    for(let i=0; i<points.length-1; i++){
      const p0 = points[i];
      const p1 = points[i+1];
      out.push(p0);
      for(let j=1; j<factor; j++){
        const m = j / factor;
        const ease = m < 0.5 ? 2*m*m : 1 - Math.pow(-2*m + 2, 2)/2;
        out.push({
          t: Math.round(p0.t + (p1.t - p0.t) * m),
          h: p0.h + (p1.h - p0.h) * ease,
          a: p0.a + (p1.a - p0.a) * ease
        });
      }
    }
    out.push(points[points.length-1]);
    return out;
  }

  function buildSyntheticAccountChart(account, workers){
    const now = Date.now();
    const steps = 36;
    const start = now - (3 * 60 * 60 * 1000);
    const stepMs = Math.round((3 * 60 * 60 * 1000) / (steps - 1));

    const accountCurrent = n(account.currentHashrate30m || account.currentHashrate, 0);
    const accountAverage = n(account.averageHashrate3h || account.averageHashrate || account.avgHashrate3h || account.avgHashrate, accountCurrent);

    const wsrc = (Array.isArray(workers) ? workers : []).map((w, idx) => {
      const current = n(w.currentHashrate30m || w.hashrate30m || w.currentHashrate || w.hashrate, 0);
      const average = n(w.averageHashrate3h || w.averageHashrate || w.hashrate3h || w.avgHashrate3h || current, current);
      const lastShare = n(w.lastShare || w.lastShareTime, now);
      const offline = !!w.offline;
      return {
        idx,
        current,
        average: average || current,
        lastShare,
        offline
      };
    }).filter(w => (w.current > 0 || w.average > 0));

    const points = [];

    for(let i=0; i<steps; i++){
      const t = start + i * stepMs;
      const progress = i / (steps - 1);

      let h = 0;
      let a = 0;

      if (wsrc.length){
        wsrc.forEach((w) => {
          const phase = (w.idx + 1) * 0.85;
          const wave1 = Math.sin(progress * Math.PI * 2.2 + phase) * 0.035;
          const wave2 = Math.cos(progress * Math.PI * 4.3 + phase * 1.7) * 0.018;

          let freshness = 1;
          if (t > w.lastShare){
            const idleMs = t - w.lastShare;
            if (idleMs > 30 * 60 * 1000){
              freshness = Math.max(0, 1 - ((idleMs - 30 * 60 * 1000) / (90 * 60 * 1000)));
            }
          }
          if (w.offline) freshness *= 0.15;

          const curBase = w.average + (w.current - w.average) * progress;
          const avgBase = w.average;

          const curVal = Math.max(0, curBase * (1 + wave1 + wave2) * freshness);
          const avgVal = Math.max(0, avgBase * (1 + wave1 * 0.35) * Math.max(0.45, 0.65 + freshness * 0.35));

          h += curVal;
          a += avgVal;
        });
      } else {
        const wave1 = Math.sin(progress * Math.PI * 2.0) * 0.03;
        const wave2 = Math.cos(progress * Math.PI * 4.8) * 0.015;
        h = Math.max(0, (accountAverage + (accountCurrent - accountAverage) * progress) * (1 + wave1 + wave2));
        a = Math.max(0, accountAverage * (1 + wave1 * 0.25));
      }

      points.push({ t, h, a });
    }

    if (points.length){
      points[points.length - 1].h = accountCurrent || points[points.length - 1].h;
      points[points.length - 1].a = accountAverage || points[points.length - 1].a;
    }

    return points;
  }

  function normalizeAccountChart(account, workers){
    const raw = normalizeRawChartPoints(account.chart || []);
    const distinctH = new Set(raw.map(p => Math.round(p.h))).size;
    const distinctA = new Set(raw.map(p => Math.round(p.a))).size;

    if (raw.length >= 8 && (distinctH >= 4 || distinctA >= 4)) {
      return densifyPoints(raw, 3);
    }

    return buildSyntheticAccountChart(account, workers);
  }


