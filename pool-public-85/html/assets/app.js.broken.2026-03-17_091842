      const d = Math.floor(h/24);
      return d === 1 ? t('dayAgo') : `${d} ${t('daysAgo')}`;
    }
    if (s < 60) return `${s} ${s===1?t('secondAgo'):t('secondsAgo')}`;
    const m = Math.floor(s/60);
